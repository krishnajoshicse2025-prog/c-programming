#include<stdio.h>
int main(){ 
    int a[100],n;
    printf("Enter no of elements in array");
    scanf("%d",&n);
    printf("Elements in array:\n");
    for(int i=0;i<n;i++){
        scanf("%d",&a[i]);
    }
    printf("Array elements are:\n");
    for(int i=0;i<n;i++){
        printf("%d",a[i]);
    }
    return 0;

}
